    <string name="sample_focus_intro">两个 OutlinedTextField：键盘「下一步」切换焦点；外层 Column 加 imePadding 减轻键盘遮挡。</string>
    <string name="sample_focus_field1">第一行</string>
    <string name="sample_focus_field2">第二行</string>
